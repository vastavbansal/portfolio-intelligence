# Portfolio Intelligence Dashboard v2 — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# ── Supabase (required for War Room manual changelog entries) ──────────────────
# Get these from: https://supabase.com/dashboard → Your Project → Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Without these, the dashboard still works — War Room will only show
# auto-generated entries. Manual entry saving will show an error message.
